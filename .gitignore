# Git worktrees (isolated workspaces for feature development)
.worktrees/

# Personal financial data exports
Balances_*.csv
Transactions_*.csv

# React build output and dependencies (compiled into frontend/dist via refresh.bat)
frontend/node_modules/
frontend/dist/

# Generated financial data payload — keep real numbers out of Git
frontend/public/data.json

# Claude Code session files
.claude/settings.local.json
.claude/plans/

# Python virtual environment
venv/

# Python bytecode cache
__pycache__/
*.pyc
*.pyo

# SQLite database (generated at runtime)
*.db

# Runtime logs
logs/

# Root-level node_modules (e.g. standalone tailwind/chart deps)
node_modules/

# Accidental pip install artifacts
=*

# Frontend environment files (may contain API keys in future)
frontend/.env
frontend/.env.local
frontend/.env.*.local
